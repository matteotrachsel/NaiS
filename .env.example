# PlantNet-API-Key (serverseitig genutzt vom Proxy /api/identify).
# Lokal: in .env eintragen. Produktion: als Vercel-Umgebungsvariable setzen.
PLANTNET_API_KEY=dein-plantnet-key

# Firebase-Web-Config für die geteilte Karte (öffentlich; Schutz via
# firestore.rules). Aus Firebase-Console -> Projekteinstellungen -> Web-App.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
